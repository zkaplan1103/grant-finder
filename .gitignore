# Secrets — never commit
.env
.env.*
!.env.example

# Database
*.db
*.sqlite
*.sqlite3

# Generated eval reports
eval_report.json

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# Frontend
node_modules/
