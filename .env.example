# Solar Grant Navigator — environment configuration
# Copy to .env and fill in. NEVER commit .env.

# Required for live agent calls (Match / Draft / Verify). Without it the app
# still boots, but running the pipeline against real LLMs will fail clearly.
ANTHROPIC_API_KEY=

# grants.gov Search2 needs no auth for basic search; left here for completeness.
GRANTS_GOV_API_KEY=
